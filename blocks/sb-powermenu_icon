#!/bin/sh

printf " ’Ćæ  "

[ "$BLOCK_BUTTON" != "1" ] && exit 0

eval "$(xdotool getmouselocation --shell)"
Z=200
X=$((X-Z))
Y=29

OPTIONS="Cancel\n’Ćæ Shutdown\n’āó Reboot\n’åå Suspend\n’āē Hibernate\n’ĆŻ Lock"

CHOICE=$(printf "%b" "$OPTIONS" | dmenu -l 6 -x "$X" -y "$Y" -z "$Z")

case "$CHOICE" in
    "’Ćæ Shutdown")   systemctl poweroff ;;
    "’āó Reboot")     systemctl reboot ;;
    "’åå Suspend")    systemctl suspend ;;
    "’āē Hibernate")  systemctl hibernate ;;
    "’ĆŻ Lock")       loginctl lock-session ;;
esac

