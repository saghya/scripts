#!/bin/sh

printf " %s’Ćæ  " "$COLOR"

case $BLOCK_BUTTON in
    1)
        eval "$(xdotool getmouselocation --shell)"
        Z=200
        X=$((X-Z))
        Y=29
        OPTIONS="Cancel\n’Ćæ Shutdown\n’āó Reboot\n’åå Sleep\n’āē Hibernate\n’ĆŻ Lock"
        SELECTED=$(echo "$OPTIONS" | dmenu -l 6 -x $X -y $Y -z $Z)

        case $SELECTED in
            "’Ćæ Shutdown") systemctl poweroff ;;
            "’āó Reboot") systemctl reboot ;;
            "’åå Sleep") systemctl suspend ;;
            "’āē Hibernate") systemctl hibernate ;;
            "’ĆŻ Lock") xset s activate ;;
            *) exit ;;
        esac ;;
esac

