#!/bin/sh

while getopts 'm:' FLAG; do
  case ${FLAG} in
    m) M_FLAG=${OPTARG} ;;
    *) ;;
  esac
done

OPTIONS="Cancel
’Ćæ Shutdown
’āó Reboot
’åå Sleep
’āē Hibernate
’ĆŻ Lock"
SELECTED=$(printf '%s\n' "$OPTIONS" | dmenu -m "$M_FLAG" -l 6 -z 220)

case "$SELECTED" in
    "’Ćæ Shutdown") systemctl poweroff ;;
    "’āó Reboot") systemctl reboot ;;
    "’åå Sleep") systemctl suspend ;;
    "’āē Hibernate") systemctl hibernate ;;
    "’ĆŻ Lock") xset s activate ;;
    *) exit ;;
esac
