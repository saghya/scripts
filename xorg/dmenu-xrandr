#!/bin/sh

# Accept the dmenu monitor index passed by dwm.
while getopts 'm:' FLAG; do
  case ${FLAG} in
    m) M_FLAG=${OPTARG} ;;
    *) ;;
  esac
done

# Count non-empty newline-separated entries.
count_lines() {
    printf '%s\n' "$1" | sed '/^$/d' | wc -l | tr -d ' '
}

# Show a list of options in dmenu.
menu() {
    PROMPT="$1"
    OPTIONS="$2"
    LINES="$(count_lines "$OPTIONS")"

    [ "$LINES" -gt 0 ] || return 1

    if [ -n "$PROMPT" ]; then
        printf '%s\n' "$OPTIONS" | dmenu -m "$M_FLAG" -l "$LINES" -i -p "$PROMPT" -z 220
    else
        printf '%s\n' "$OPTIONS" | dmenu -m "$M_FLAG" -l "$LINES" -i -z 220
    fi
}

# Return the names of outputs currently reported as connected.
connected_outputs() {
    xrandr --query | awk '/ connected/ { print $1 }'
}

# Cache the connected outputs for this invocation.
CONNECTED="$(connected_outputs)"
CONNECTED_COUNT="$(count_lines "$CONNECTED")"

# Stop early when xrandr sees no usable outputs.
if [ "$CONNECTED_COUNT" -eq 0 ]; then
    notify-send -t 1500 "xrandr" "No connected displays found"
    exit 1
fi

# Return the connected outputs except for one excluded connector.
outputs_except() {
    EXCLUDE="$1"
    printf '%s\n' "$CONNECTED" | awk -v exclude="$EXCLUDE" '$0 != exclude'
}

# Pick one output from a list, skipping dmenu when only one exists.
pick_output() {
    PROMPT="$1"
    OPTIONS="$2"
    COUNT="$(count_lines "$OPTIONS")"

    if [ "$COUNT" -eq 1 ]; then
        printf '%s\n' "$OPTIONS"
    else
        menu "$PROMPT" "$OPTIONS"
    fi
}

# Pick any connected output.
pick_any_output() {
    pick_output "Output" "$CONNECTED"
}

# Pick a reference output different from the target output.
pick_other_output() {
    OUTPUT="$1"
    pick_output "Reference" "$(outputs_except "$OUTPUT")"
}

# List the unique modes available on a specific output.
mode_list() {
    OUTPUT="$1"
    xrandr --query | awk -v output="$OUTPUT" '
        $1 == output && / connected/ { in_output=1; next }
        in_output && /^[^[:space:]]/ { exit }
        in_output && /^[[:space:]]*[0-9]+x[0-9]+/ { print $1 }
    ' | awk '!seen[$0]++'
}

# Pick one mode for an output.
pick_mode() {
    OUTPUT="$1"
    MODES="$(mode_list "$OUTPUT")"
    [ -n "$MODES" ] || return 1
    menu "$OUTPUT mode" "$MODES"
}

# Read the currently active mode from xrandr's `*` marker.
current_mode() {
    OUTPUT="$1"
    xrandr --query | awk -v output="$OUTPUT" '
        $1 == output && / connected/ { in_output=1; next }
        in_output && /^[^[:space:]]/ { exit }
        in_output && /\*/ { print $1; exit }
    '
}

# Parse width, height, x offset and y offset from xrandr geometry.
output_geometry() {
    OUTPUT="$1"
    xrandr --query | awk -v output="$OUTPUT" '
        $1 == output && / connected/ { print; exit }
    ' | sed -nE 's/.* ([0-9]+)x([0-9]+)\+(-?[0-9]+)\+(-?[0-9]+).*/\1 \2 \3 \4/p'
}

# Re-enable an output while keeping its current mode when possible.
enable_current_mode() {
    OUTPUT="$1"
    shift

    MODE="$(current_mode "$OUTPUT")"

    if [ -n "$MODE" ]; then
        xrandr --output "$OUTPUT" --mode "$MODE" "$@"
    else
        xrandr --output "$OUTPUT" --auto "$@"
    fi
}

# Return only the outputs that are currently part of the active layout.
active_outputs() {
    # Only outputs with a mode+offset geometry are currently part of the layout.
    for OUTPUT in $CONNECTED; do
        if [ -n "$(output_geometry "$OUTPUT")" ]; then
            printf '%s\n' "$OUTPUT"
        fi
    done
}

# Infer the target output's current relation to another active output.
current_relation() {
    TARGET="$1"

    read -r TARGET_W TARGET_H TARGET_X TARGET_Y <<EOF
$(output_geometry "$TARGET")
EOF

    [ -n "${TARGET_W:-}" ] || return 1

    # Infer the current spatial relation from exact edges so we can reapply it
    # after changing a mode without leaving stale gaps behind.
    for REF in $(active_outputs); do
        [ "$REF" = "$TARGET" ] && continue

        read -r REF_W REF_H REF_X REF_Y <<EOF
$(output_geometry "$REF")
EOF

        [ -n "${REF_W:-}" ] || continue

        if [ "$TARGET_X" -eq "$REF_X" ] && [ "$TARGET_Y" -eq "$REF_Y" ]; then
            printf '%s %s\n' "$REF" mirror
            return
        fi

        if [ "$TARGET_X" -eq $((REF_X + REF_W)) ]; then
            printf '%s %s\n' "$REF" right-of
            return
        fi

        if [ $((TARGET_X + TARGET_W)) -eq "$REF_X" ]; then
            printf '%s %s\n' "$REF" left-of
            return
        fi

        if [ "$TARGET_Y" -eq $((REF_Y + REF_H)) ]; then
            printf '%s %s\n' "$REF" below
            return
        fi

        if [ $((TARGET_Y + TARGET_H)) -eq "$REF_Y" ]; then
            printf '%s %s\n' "$REF" above
            return
        fi
    done
}

# Compute the set of resolutions that two outputs can both mirror.
common_modes() {
    LEFT="$1"
    RIGHT="$2"

    LEFT_MODES="$(mode_list "$LEFT")"
    RIGHT_MODES="$(mode_list "$RIGHT")"

    for MODE in $LEFT_MODES; do
        for RIGHT_MODE in $RIGHT_MODES; do
            if [ "$MODE" = "$RIGHT_MODE" ]; then
                printf '%s\n' "$MODE"
                break
            fi
        done
    done | awk '!seen[$0]++'
}

# Mirror TARGET onto SOURCE, preferring SOURCE's current mode when possible.
mirror_outputs() {
    SOURCE="$1"
    TARGET="$2"
    COMMON="$(common_modes "$SOURCE" "$TARGET")"

    [ -n "$COMMON" ] || exit

    SOURCE_MODE="$(current_mode "$SOURCE")"
    MODE="$SOURCE_MODE"

    # Prefer the current source mode when both outputs support it.
    case " $COMMON " in
        *" $SOURCE_MODE "*) ;;
        *)
            MODE="$(pick_output "Mirror mode" "$COMMON")"
            ;;
    esac

    [ -n "$MODE" ] || exit

    xrandr --output "$SOURCE" --mode "$MODE" --output "$TARGET" --mode "$MODE" --same-as "$SOURCE"
}

# Change one output's mode and restore its previous relative placement.
set_resolution() {
    OUTPUT="$1"
    MODE="$2"

    read -r REF RELATION <<EOF
$(current_relation "$OUTPUT")
EOF

    xrandr --output "$OUTPUT" --mode "$MODE"

    # Reapply the previous relation so resizing does not keep stale coordinates.
    if [ -z "${REF:-}" ] || [ -z "${RELATION:-}" ]; then
        exit 0
    fi

    case "$RELATION" in
        mirror)
            mirror_outputs "$REF" "$OUTPUT"
            ;;
        right-of)
            enable_current_mode "$OUTPUT" --right-of "$REF"
            ;;
        left-of)
            enable_current_mode "$OUTPUT" --left-of "$REF"
            ;;
        above)
            enable_current_mode "$OUTPUT" --above "$REF"
            ;;
        below)
            enable_current_mode "$OUTPUT" --below "$REF"
            ;;
    esac
}

# Reposition one output relative to another without resetting its mode.
position_output() {
    TARGET="$1"
    REF="$2"
    RELATION="$3"

    # Move the target while keeping its current mode intact.
    case "$RELATION" in
        right-of)
            enable_current_mode "$TARGET" --right-of "$REF"
            ;;
        left-of)
            enable_current_mode "$TARGET" --left-of "$REF"
            ;;
        above)
            enable_current_mode "$TARGET" --above "$REF"
            ;;
        below)
            enable_current_mode "$TARGET" --below "$REF"
            ;;
    esac
}

# Keep one output enabled and turn every other connected output off.
only_output() {
    KEEP="$1"

    # Preserve the chosen output's current mode while disabling everything else.
    enable_current_mode "$KEEP" --primary

    for OUTPUT in $CONNECTED; do
        [ "$OUTPUT" = "$KEEP" ] && continue
        xrandr --output "$OUTPUT" --off
    done
}

# Top-level actions for multi-monitor layouts.
ACTIONS="Set resolution
Position output
Mirror outputs
Set primary
Only output
Disable output"

# Trim the menu when only one output is connected.
[ "$CONNECTED_COUNT" -eq 1 ] && ACTIONS="Set resolution
Set primary"

# Dispatch the selected action.
case $(menu "" "$ACTIONS") in
    "Set resolution")
        OUTPUT="$(pick_any_output)"
        [ -n "$OUTPUT" ] || exit
        MODE="$(pick_mode "$OUTPUT")"
        [ -n "$MODE" ] || exit
        set_resolution "$OUTPUT" "$MODE"
        ;;
    "Position output")
        [ "$CONNECTED_COUNT" -gt 1 ] || exit
        TARGET="$(pick_any_output)"
        [ -n "$TARGET" ] || exit
        REF="$(pick_other_output "$TARGET")"
        [ -n "$REF" ] || exit
        RELATION="$(menu "Position" "Right of $REF
Left of $REF
Above $REF
Below $REF")"
        case "$RELATION" in
            "Right of $REF") position_output "$TARGET" "$REF" right-of ;;
            "Left of $REF") position_output "$TARGET" "$REF" left-of ;;
            "Above $REF") position_output "$TARGET" "$REF" above ;;
            "Below $REF") position_output "$TARGET" "$REF" below ;;
            *) exit ;;
        esac
        ;;
    "Mirror outputs")
        [ "$CONNECTED_COUNT" -gt 1 ] || exit
        SOURCE="$(pick_any_output)"
        [ -n "$SOURCE" ] || exit
        TARGET="$(pick_other_output "$SOURCE")"
        [ -n "$TARGET" ] || exit
        mirror_outputs "$SOURCE" "$TARGET"
        ;;
    "Set primary")
        OUTPUT="$(pick_any_output)"
        [ -n "$OUTPUT" ] || exit
        xrandr --output "$OUTPUT" --primary
        ;;
    "Only output")
        [ "$CONNECTED_COUNT" -gt 1 ] || exit
        OUTPUT="$(pick_any_output)"
        [ -n "$OUTPUT" ] || exit
        only_output "$OUTPUT"
        ;;
    "Disable output")
        [ "$CONNECTED_COUNT" -gt 1 ] || exit
        OUTPUT="$(pick_any_output)"
        [ -n "$OUTPUT" ] || exit
        xrandr --output "$OUTPUT" --off
        ;;
    *) exit ;;
esac

