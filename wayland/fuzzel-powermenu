#!/bin/sh

OPTIONS="Cancel
´Çæ Shutdown
´âó Reboot
´åå Sleep
´âë Hibernate
´Çú Lock"
SELECTED=$(printf '%s\n' "$OPTIONS" | fuzzel --dmenu --minimal-lines -w 15)

case "$SELECTED" in
    "´Çæ Shutdown") systemctl poweroff ;;
    "´âó Reboot") systemctl reboot ;;
    "´åå Sleep") systemctl suspend ;;
    "´âë Hibernate") systemctl hibernate ;;
    "´Çú Lock") hyprlock ;;
    *) exit ;;
esac

